{
  "paths": {
    "input_data": "../data/timeseries.npy",
    "symbolic_output_root": "../outputs/representation",
    "hmm_output_root": "../outputs/hmm",
    "score_output_root": "../outputs/score",
    "figure_output_root": "../outputs/figures",
    "metadata_csv": "../your_metadata.csv",
    "dataset_npz": "../data/dataset.npz",
    "roi_mapping_xlsx": "../data/Mapping.xlsx"
  },
  "preprocess": {
    "standardize_method": "zscore",
    "smooth": false,
    "smooth_window": 3,
    "center_diff_on_diff_series": true,
    "fill_first_diff": "zero"
  },
  "representation": {
    "mode": "gaussian_2d",
    "use_activation": true,
    "use_trend": true,
    "activation_thresholds": [0.6, 0.7],
    "trend_thresholds": [0.6, 0.7],
    "alpha_values": [1.0],
    "beta_values": [1.0],
    "activation_encoding": "ternary",
    "trend_encoding": "ternary",
    "feature_standardize": false
  },
  "hmm": {
    "emission_type": "gaussian",
    "covariance_type": "full",
    "n_hidden_states_values": [5, 6, 7],
    "n_iter": 200,
    "tol": 0.0001,
    "random_state": 128,
    "verbose": true
  },
  "score": {
    "weights": {
      "fo": 1.0,
      "mdt": 1.0
    },
    "normalize_scores_across_runs": true
  },
  "visualization": {
    "dpi": 300,
    "fig_format": "png",
    "top_n_score_runs": 10,
    "show_titles": true,
    "save_symbolic_distribution": true,
    "save_transition_matrix": true,
    "save_fo_bar": true,
    "save_mdt_bar": true,
    "save_score_bar": true
  }
}